# NanoWebUI Configuration
# Copy this file to .env and adjust values as needed

# Server
HOST=0.0.0.0
PORT=3000

# JWT secret — CHANGE THIS IN PRODUCTION
NANOWEBUI_SECRET_KEY=change-me-to-a-random-string

# Nanobot config path (default: ~/.nanobot/config.json)
# NANOBOT_CONFIG_PATH=/path/to/config.json

# Remote mode — set this to connect to a remote nanobot instance
# When set, gateway control and log streaming are disabled
# NANOBOT_URL=http://localhost:18790
